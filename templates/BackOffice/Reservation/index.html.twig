{% extends 'BackOffice/base.html.twig' %}

{% block title %}Réservations | EcoTrip Admin{% endblock %}
{% block page_title %}Réservations{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.res-filters { background: #fff; border-radius: 16px; padding: 20px 24px; margin-bottom: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; }
.res-filters .form-row { display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end; }
.res-filters .form-group { margin: 0; min-width: 140px; }
.res-filters label { font-size: 0.8rem; color: #64748b; margin-bottom: 4px; display: block; }
.res-filters select, .res-filters input { padding: 8px 12px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%; }
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 16px; margin-bottom: 24px; }
.stat-card { background: #fff; border-radius: 16px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; }
.stat-card h3 { font-size: 1.75rem; font-weight: 700; margin: 0 0 4px 0; color: #0f172a; }
.stat-card p { margin: 0; font-size: 0.8rem; color: #64748b; }
.table-wrap { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; }
.res-table { width: 100%; border-collapse: collapse; }
.res-table th, .res-table td { padding: 14px 16px; text-align: left; border-bottom: 1px solid #f1f5f9; }
.res-table th { background: #f8fafc; font-weight: 600; font-size: 0.8rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
.res-table tr:hover { background: #f8fafc; }
.res-table .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
.res-table .btn { padding: 6px 12px; font-size: 0.85rem; margin-right: 4px; }
.res-loading { opacity: 0.6; pointer-events: none; position: relative; }
.res-loading::after { content: ''; position: absolute; top: 50%; left: 50%; width: 40px; height: 40px; margin: -20px 0 0 -20px; border: 3px solid #e2e8f0; border-top-color: #2d5016; border-radius: 50%; animation: res-spin 0.8s linear infinite; }
@keyframes res-spin { to { transform: rotate(360deg); } }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger">{{ flash }}</div>
    {% endfor %}

    {# Filters #}
    <div class="res-filters">
        <form method="get" action="{{ path('app_reservation_index') }}" id="reservationFilterForm">
            <div class="form-row">
                <div class="form-group">
                    <label>Statut</label>
                    <select name="status">
                        <option value="">Tous</option>
                        <option value="PENDING" {{ filters.status == 'PENDING' ? 'selected' : '' }}>En attente</option>
                        <option value="CONFIRMED" {{ filters.status == 'CONFIRMED' ? 'selected' : '' }}>Confirmée</option>
                        <option value="CANCELLED" {{ filters.status == 'CANCELLED' ? 'selected' : '' }}>Annulée</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Type</label>
                    <select name="type">
                        <option value="">Tous</option>
                        <option value="HEBERGEMENT" {{ filters.type == 'HEBERGEMENT' ? 'selected' : '' }}>Hébergement</option>
                        <option value="ACTIVITY" {{ filters.type == 'ACTIVITY' ? 'selected' : '' }}>Activité</option>
                        <option value="TRANSPORT" {{ filters.type == 'TRANSPORT' ? 'selected' : '' }}>Transport</option>
                    </select>
                </div>
                <div class="form-group" style="min-width: 200px;">
                    <label>Utilisateur (email / nom)</label>
                    <input type="text" name="user" id="reservationUserSearch" value="{{ filters.user|default('') }}" placeholder="Rechercher...">
                </div>
                <div class="form-group">
                    <label>Date début</label>
                    <input type="date" name="date_from" value="{{ filters.date_from|default('') }}">
                </div>
                <div class="form-group">
                    <label>Date fin</label>
                    <input type="date" name="date_to" value="{{ filters.date_to|default('') }}">
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-success"><i class="fa fa-search"></i> Filtrer</button>
                </div>
            </div>
        </form>
    </div>

    {# Stats #}
    <div class="stats-grid" id="reservationStats">
        <div class="stat-card" data-stat="total">
            <h3>{{ stats.total }}</h3>
            <p>Total réservations</p>
        </div>
        <div class="stat-card" data-stat="pending">
            <h3>{{ stats.pending }}</h3>
            <p>En attente</p>
        </div>
        <div class="stat-card" data-stat="confirmed">
            <h3>{{ stats.confirmed }}</h3>
            <p>Confirmées</p>
        </div>
        <div class="stat-card" data-stat="cancelled">
            <h3>{{ stats.cancelled }}</h3>
            <p>Annulées</p>
        </div>
        <div class="stat-card" data-stat="revenue">
            <h3>{{ stats.revenue|number_format(2, ',', ' ') }} TND</h3>
            <p>Chiffre d'affaires (confirmées)</p>
        </div>
    </div>

    {# Table #}
    <div class="table-wrap">
        <table class="res-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Utilisateur</th>
                    <th>Type</th>
                    <th>Élément</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th>Personnes</th>
                    <th>Total</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="reservationTbody">
                {% for item in items %}
                    {% set r = item.reservation %}
                    <tr>
                        <td>{{ r.id }}</td>
                        <td>
                            {{ r.user.email }}
                            {% if r.user.username %}<br><small class="text-muted">{{ r.user.username }}</small>{% endif %}
                        </td>
                        <td>{{ item.typeLabel }}</td>
                        <td>{{ item.label }}</td>
                        <td>{{ r.dateFrom ? r.dateFrom|date('d/m/Y') : '-' }}</td>
                        <td>{{ r.dateTo ? r.dateTo|date('d/m/Y') : '-' }}</td>
                        <td>{{ r.numberOfPersons }}</td>
                        <td>{{ r.totalPrice|number_format(2, ',', ' ') }} TND</td>
                        <td>
                            <span class="badge badge-{{ r.status.badge() }}">{{ r.status.label() }}</span>
                        </td>
                        <td>
                            <a href="{{ path('app_reservation_show', { id: r.id }) }}" class="btn btn-sm btn-primary"><i class="fa fa-eye"></i> Voir</a>
                            <form method="post" action="{{ path('app_reservation_delete', { id: r.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer cette réservation ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('reservation_delete_' ~ r.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fa fa-trash"></i> Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="10" class="text-center text-muted py-5">Aucune réservation trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
(function() {
    var form = document.getElementById('reservationFilterForm');
    var tbody = document.getElementById('reservationTbody');
    var statsContainer = document.getElementById('reservationStats');
    var tableWrap = document.querySelector('.table-wrap');
    var indexUrl = '{{ path('app_reservation_index') }}';
    var userInput = document.getElementById('reservationUserSearch');
    var debounceTimer = null;

    function formatRevenue(num) {
        return parseFloat(num).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' TND';
    }

    function updateStats(data) {
        if (!data.stats) return;
        var s = data.stats;
        statsContainer.querySelector('[data-stat="total"] h3').textContent = s.total;
        statsContainer.querySelector('[data-stat="pending"] h3').textContent = s.pending;
        statsContainer.querySelector('[data-stat="confirmed"] h3').textContent = s.confirmed;
        statsContainer.querySelector('[data-stat="cancelled"] h3').textContent = s.cancelled;
        statsContainer.querySelector('[data-stat="revenue"] h3').textContent = formatRevenue(s.revenue);
    }

    function loadFilters() {
        if (!form || !tbody) return;
        tableWrap.classList.add('res-loading');
        var params = new URLSearchParams(new FormData(form));
        params.set('partial', '1');
        fetch(indexUrl + '?' + params.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                updateStats(data);
                tbody.innerHTML = data.html || '';
            })
            .catch(function() {
                form.submit();
            })
            .finally(function() {
                tableWrap.classList.remove('res-loading');
            });
    }

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        loadFilters();
    });

    if (userInput) {
        userInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(loadFilters, 400);
        });
    }

    document.querySelectorAll('#reservationFilterForm select').forEach(function(sel) {
        sel.addEventListener('change', loadFilters);
    });
})();
</script>
{% endblock %}
