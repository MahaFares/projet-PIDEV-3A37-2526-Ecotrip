{% extends 'base.html.twig' %}

{% block title %}AI Transport Recommendation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .reco-hero {
            background: linear-gradient(135deg, #2d5016 0%, #1e4620 100%);
            color: #fff;
            border-radius: 1rem;
            padding: 2rem 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 12px 30px rgba(30, 70, 32, 0.25);
        }

        .reco-hero h1 {
            margin: 0;
            font-size: 2rem;
            font-weight: 800;
        }

        .reco-hero p {
            margin: 0.4rem 0 0;
            color: rgba(255, 255, 255, 0.9);
        }

        .field-label-icon {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-weight: 700;
            margin-bottom: 0.35rem;
        }

        .btn-submit-reco {
            width: 100%;
            padding: 0.9rem 1.2rem;
            font-size: 1.05rem;
            font-weight: 800;
            border-radius: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
{% endblock %}

{% block body %}
<section class="container py-5" style="max-width: 780px;">
    <div class="reco-hero">
        <h1>Find Your Perfect Eco Ride &#x1F33F;</h1>
        <p>Set your route and priorities, then get top AI-powered transport suggestions.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
            <h2 class="mb-3">AI Transport Recommendation</h2>
            <p class="text-muted mb-4">Tell us your route and preference, and we will rank the top 3 transport options.</p>

            {{ form_start(form) }}
                <div class="mb-3">
                    <label for="{{ form.origin.vars.id }}" class="field-label-icon">&#x1F4CD; {{ form.origin.vars.label }}</label>
                    {{ form_widget(form.origin, { attr: { class: 'form-control', placeholder: 'e.g. Tunis' } }) }}
                    {{ form_errors(form.origin) }}
                </div>

                <div class="mb-3">
                    <label for="{{ form.destination.vars.id }}" class="field-label-icon">&#x1F4CD; {{ form.destination.vars.label }}</label>
                    {{ form_widget(form.destination, { attr: { class: 'form-control', placeholder: 'e.g. Sousse' } }) }}
                    {{ form_errors(form.destination) }}
                </div>

                <div class="mb-3">
                    <label for="{{ form.passengers.vars.id }}" class="field-label-icon">&#x1F465; {{ form.passengers.vars.label }}</label>
                    {{ form_widget(form.passengers, { attr: { class: 'form-control', min: 1 } }) }}
                    {{ form_errors(form.passengers) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="{{ form.budgetMin.vars.id }}" class="field-label-icon">&#x1F4B0; {{ form.budgetMin.vars.label }}</label>
                        {{ form_widget(form.budgetMin, { attr: { class: 'form-control', min: 0, step: '0.01', placeholder: 'e.g. 20' } }) }}
                        {{ form_errors(form.budgetMin) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="{{ form.budgetMax.vars.id }}" class="field-label-icon">&#x1F4B0; {{ form.budgetMax.vars.label }}</label>
                        {{ form_widget(form.budgetMax, { attr: { class: 'form-control', min: 0, step: '0.01', placeholder: 'e.g. 80' } }) }}
                        {{ form_errors(form.budgetMax) }}
                    </div>
                </div>

                <div class="mb-4">
                    <label for="{{ form.preference.vars.id }}" class="field-label-icon">&#x26A1; {{ form.preference.vars.label }}</label>
                    {{ form_widget(form.preference, { attr: { class: 'form-select form-control' } }) }}
                    {{ form_errors(form.preference) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.comfortLevel) }}
                    {{ form_widget(form.comfortLevel, { attr: { class: 'form-select form-control' } }) }}
                    {{ form_errors(form.comfortLevel) }}
                </div>

                <button type="submit" class="btn theme_btn btn-submit-reco">Get Recommendations</button>
            {{ form_end(form) }}
        </div>
    </div>
</section>
{% endblock %}
