{% extends 'base.html.twig' %}

{% block title %}Recommended Transports{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .results-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 1.25rem;
        }

        .btn-try-again {
            background: linear-gradient(135deg, #2d5016 0%, #1e4620 100%);
            color: #fff;
            border: 0;
            border-radius: 0.6rem;
            padding: 0.65rem 1rem;
            font-weight: 700;
            text-decoration: none;
        }

        .btn-try-again:hover {
            color: #fff;
            text-decoration: none;
            opacity: 0.95;
        }

        .transport-reco-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 0.75rem;
            margin-bottom: 1rem;
            background: #f1f5f9;
        }

        .transport-reco-image-placeholder {
            width: 100%;
            height: 180px;
            border-radius: 0.75rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            color: #64748b;
            font-weight: 600;
        }

        .medal {
            font-size: 1.35rem;
            margin-right: 0.3rem;
        }

        .co2-label {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 0.35rem;
        }

        .btn-reserve {
            width: 100%;
            background: linear-gradient(135deg, #2d5016 0%, #1e4620 100%);
            color: white;
            border: none;
            padding: 12px 16px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            margin-top: 1rem;
        }

        .btn-reserve:disabled {
            background: linear-gradient(135deg, #9e9e9e 0%, #757575 100%);
            cursor: not-allowed;
            opacity: 0.6;
        }

        .btn-reserve:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(45, 80, 22, 0.25);
        }

        .btn-success-animation {
            animation: successPop 0.4s ease;
        }

        @keyframes successPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.06); }
            100% { transform: scale(1); }
        }
    </style>
{% endblock %}

{% block body %}
<section class="container py-5">
    <div class="results-topbar">
        <div>
            <h2 class="mb-1">Top 3 Recommended Transports</h2>
            <p class="text-muted mb-0">
                From {{ input.origin }} to {{ input.destination }}
                | {{ input.passengers }} passenger(s)
                | Preference: <strong>{{ input.preference }}</strong>
                | Budget: <strong>{{ input.budgetMin is not null ? input.budgetMin : 'Any' }} - {{ input.budgetMax is not null ? input.budgetMax : 'Any' }}</strong>
                | Comfort: <strong>{{ input.comfortLevel }}</strong>
            </p>
        </div>
        <a href="{{ path('app_transport_recommend') }}" class="btn-try-again">Try Again</a>
    </div>

    {% for flash in app.flashes('warning') %}
        <div class="alert alert-warning">{{ flash }}</div>
    {% endfor %}

    {% if recommendations is empty %}
        <div class="alert alert-info">No available transport could be ranked right now.</div>
    {% else %}
        {% set co2Values = [] %}
        {% for reco in recommendations %}
            {% set co2Values = co2Values|merge([reco.transport.emissionco2|default(0)]) %}
        {% endfor %}
        {% set minCo2 = co2Values ? min(co2Values) : 0 %}
        {% set maxCo2 = co2Values ? max(co2Values) : 0 %}
        {% set co2Range = maxCo2 - minCo2 %}

        <div class="row g-4">
            {% for item in recommendations %}
                {% set co2Value = item.transport.emissionco2|default(0) %}
                {% set co2Score = co2Range > 0 ? ((co2Value - minCo2) / co2Range * 100) : 0 %}
                {% set co2Class = co2Score <= 33 ? 'bg-success' : (co2Score <= 66 ? 'bg-warning' : 'bg-danger') %}
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            {% if item.transport.image %}
                                <img
                                    src="{{ item.transport.image starts with 'http' ? item.transport.image : asset('uploads/transports/' ~ item.transport.image) }}"
                                    alt="{{ item.transport.type }}"
                                    class="transport-reco-image"
                                >
                            {% else %}
                                <div class="transport-reco-image-placeholder">No image available</div>
                            {% endif %}

                            <h4 class="mb-3">
                                <span class="medal">
                                    {% if loop.index == 1 %}&#x1F947;{% elseif loop.index == 2 %}&#x1F948;{% else %}&#x1F949;{% endif %}
                                </span>
                                {{ item.transport.type }}
                            </h4>

                            <ul class="list-unstyled mb-3">
                                <li><strong>Category:</strong> {{ item.transport.category ? item.transport.category.name : 'Uncategorized' }}</li>
                                <li><strong>CO2 Emission:</strong> {{ item.transport.emissionco2 }}</li>
                                <li><strong>Price / Person:</strong> {{ item.transport.prixparpersonne }}</li>
                                <li><strong>Capacity:</strong> {{ item.transport.capacite }}</li>
                            </ul>

                            <div class="co2-label">CO2 level compared to these 3 results</div>
                            <div class="progress mb-3" role="progressbar" aria-label="CO2 comparison bar">
                                <div class="progress-bar {{ co2Class }}" style="width: {{ co2Score }}%"></div>
                            </div>

                            <span class="badge bg-success-subtle text-success p-3" style="white-space: normal; line-height: 1.4;">
                                {{ item.explanation }}
                            </span>

                            <button
                                type="button"
                                class="btn-reserve"
                                data-transport-id="{{ item.transport.id }}"
                                data-url="{{ path('app_panier_add_transport', {id: item.transport.id}) }}"
                                {% if item.transport.disponible is defined and not item.transport.disponible %}disabled{% endif %}
                            >
                                <span>{% if item.transport.disponible is defined and item.transport.disponible %}Book This Transport{% else %}Not Available{% endif %}</span>
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.btn-reserve').forEach(btn => {
                btn.addEventListener('click', function() {
                    const originalHTML = this.innerHTML;
                    this.innerHTML = '<span>Adding...</span>';
                    this.disabled = true;

                    fetch(this.dataset.url, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                        .then(r => r.json())
                        .then(d => {
                            if (d.success) {
                                this.innerHTML = '<span>&#10003; Added!</span>';
                                this.classList.add('btn-success-animation');
                                this.style.background = 'linear-gradient(135deg, #4CAF50 0%, #45a049 100%)';

                                if (typeof updateCartBadge === 'function') {
                                    updateCartBadge(d.count);
                                }

                                setTimeout(() => {
                                    this.innerHTML = originalHTML;
                                    this.disabled = false;
                                    this.style.background = '';
                                    this.classList.remove('btn-success-animation');
                                }, 2000);
                            } else {
                                this.innerHTML = '<span>&#10007; Error</span>';
                                this.style.background = 'linear-gradient(135deg, #f44336 0%, #d32f2f 100%)';
                                setTimeout(() => {
                                    this.innerHTML = originalHTML;
                                    this.disabled = false;
                                    this.style.background = '';
                                }, 2000);
                            }
                        })
                        .catch(() => {
                            this.innerHTML = originalHTML;
                            this.disabled = false;
                        });
                });
            });
        });
    </script>
{% endblock %}
