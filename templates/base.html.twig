<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="icon" href="{{ asset('images/favicon.png') }}" type="image/png">
    <title>{% block title %}EcoTrip{% endblock %}</title>
    <!-- Global CSS -->
    <link href="{{ asset('css/bootstrap.css') }}" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('vendors/linericon/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/font-awesome.min.css') }}">
    <link rel="stylesheet" href="{{ asset('vendors/bootstrap-datepicker/bootstrap-datetimepicker.min.css') }}">
    <link rel="stylesheet" href="{{ asset('vendors/nice-select/css/nice-select.css') }}">
    <link rel="stylesheet" href="{{ asset('vendors/owl-carousel/owl.carousel.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/responsive.css') }}">
    <!-- Global theme overrides (logo, buttons) -->
    <style>
        .navbar-brand.logo_h img { max-height: 100px !important; width: auto !important; object-fit: contain; }
        .theme_btn, .button_hover, .btn.theme_btn, .book_now_btn, .theme_btn_two {
            background-color: #2d5016 !important; border-color: #2d5016 !important; color: #fff !important;
        }
        .theme_btn:hover, .button_hover:hover, .btn.theme_btn:hover, .book_now_btn:hover, .theme_btn_two:hover {
            background-color: #1e4620 !important; border-color: #1e4620 !important;
        }
        /* Language dropdown */
        .navbar .menu_nav .nav-item.lang-dropdown { margin-left: 30px !important; }
        .navbar .dropdown-menu { min-width: 150px !important; background: #fff !important; box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important; border-radius: 8px !important; }
        .navbar .dropdown-menu .dropdown-item:hover { background: #f0f7ed !important; color: #2d5016 !important; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!--================Header Area =================-->
    {% include 'navbar.html.twig' with { active_route: app.request.attributes.get('_route') } only %}
    <!--================Header Area =================-->

    {% block body %}{% endblock %}

    <!--================Footer Area =================-->
    {% include 'footer.html.twig' %}
    <!--================End Footer Area =================-->

    <!-- Global JavaScript (defer = load in parallel, run after DOM; keeps order) -->
    <script src="{{ asset('js/jquery-3.2.1.min.js') }}" defer></script>
    <script src="{{ asset('js/popper.js') }}" defer></script>
    <script src="{{ asset('js/bootstrap.min.js') }}" defer></script>
    <script src="{{ asset('vendors/owl-carousel/owl.carousel.min.js') }}" defer></script>
    <script src="{{ asset('js/jquery.ajaxchimp.min.js') }}" defer></script>
    <script src="{{ asset('vendors/bootstrap-datepicker/bootstrap-datetimepicker.min.js') }}" defer></script>
    <script src="{{ asset('vendors/nice-select/js/jquery.nice-select.js') }}" defer></script>
    <script src="{{ asset('js/mail-script.js') }}" defer></script>
    <script src="{{ asset('js/stellar.js') }}" defer></script>
    <script src="{{ asset('vendors/lightbox/simpleLightbox.min.js') }}" defer></script>
    <script src="{{ asset('js/custom.js') }}" defer></script>
    <script>window.updateCartBadge = function(c) { var b = document.getElementById('cartBadge'); if(b) { b.textContent = c; b.style.display = c > 0 ? '' : 'none'; } };</script>
    <div id="ecotripToastContainer" aria-live="polite" style="position:fixed;bottom:24px;right:24px;z-index:99999;display:flex;flex-direction:column;gap:10px;max-width:360px;pointer-events:none;"></div>
    <script>
    window.showToast = function(msg, type) {
        type = type || 'success';
        var container = document.getElementById('ecotripToastContainer');
        if (!container) return;
        var el = document.createElement('div');
        el.setAttribute('role', 'alert');
        el.className = 'ecotrip-toast ecotrip-toast-' + type;
        el.style.cssText = 'pointer-events:auto;padding:14px 20px;border-radius:12px;box-shadow:0 10px 40px rgba(0,0,0,0.15);font-size:0.95rem;font-weight:500;animation:ecotripToastIn 0.35s ease;display:flex;align-items:center;gap:10px;';
        el.style.background = type === 'success' ? 'linear-gradient(135deg,#166534 0%,#15803d 100%)' : type === 'error' ? 'linear-gradient(135deg,#b91c1c 0%,#dc2626 100%)' : 'linear-gradient(135deg,#1e3a5f 0%,#2563eb 100%)';
        el.style.color = '#fff';
        el.innerHTML = (type === 'success' ? '<i class="fa fa-check-circle" style="font-size:1.2rem;flex-shrink:0;"></i>' : type === 'error' ? '<i class="fa fa-exclamation-circle" style="font-size:1.2rem;flex-shrink:0;"></i>' : '<i class="fa fa-info-circle" style="font-size:1.2rem;flex-shrink:0;"></i>') + '<span>' + (msg || '') + '</span>';
        container.appendChild(el);
        setTimeout(function() { el.style.animation = 'ecotripToastOut 0.3s ease forwards'; setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 300); }, 3800);
    };
    </script>
    <style>
    @keyframes ecotripToastIn { from { opacity:0; transform: translateX(100%); } to { opacity:1; transform: translateX(0); } }
    @keyframes ecotripToastOut { from { opacity:1; transform: translateX(0); } to { opacity:0; transform: translateX(100%); } }
    </style>
    <script src="{{ asset('js/translator.js') }}"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
