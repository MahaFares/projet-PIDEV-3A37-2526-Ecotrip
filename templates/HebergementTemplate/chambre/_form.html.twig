{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="card-body p-4 p-md-5">
            <h5 class="fw-bold text-dark mb-4 pb-2 border-bottom">
                <i class="bi bi-door-open text-primary me-2"></i>Détails de la Chambre
            </h5>
            
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="form-floating">
                        {{ form_widget(form.numero, {'attr': {'class': 'form-control', 'placeholder': 'Numéro'}}) }}
                        {{ form_label(form.numero, 'Numéro de Chambre') }}
                        {{ form_errors(form.numero) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        {{ form_widget(form.type, {'attr': {'class': 'form-control', 'placeholder': 'Type'}}) }}
                        {{ form_label(form.type, 'Type de Chambre') }}
                        {{ form_errors(form.type) }}
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="form-floating">
                        {{ form_widget(form.capacite, {'attr': {'class': 'form-control', 'placeholder': 'Capacité'}}) }}
                        {{ form_label(form.capacite) }}
                        {{ form_errors(form.capacite) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-end mb-1">
                         <button type="button" class="btn btn-xs btn-outline-success rounded-pill py-0" id="btn-suggest-price" style="font-size: 0.8rem;">
                            <i class="fas fa-robot me-1"></i> Suggérer prix
                        </button>
                    </div>
                    <div class="form-floating">
                        {{ form_widget(form.prixParNuit, {'attr': {'class': 'form-control', 'placeholder': 'Prix', 'step': '0.01', 'id': 'chambre_prix'}}) }}
                        {{ form_label(form.prixParNuit, 'Prix par Nuit (DT)') }}
                        {{ form_errors(form.prixParNuit) }}
                    </div>
                </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const btnSuggest = document.getElementById('btn-suggest-price');
                const priceInput = document.getElementById('chambre_prix');
                
                if(btnSuggest) {
                    btnSuggest.addEventListener('click', function() {
                        const originalText = btnSuggest.innerHTML;
                        btnSuggest.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ...';
                        btnSuggest.disabled = true;

                        try {
                            const form = btnSuggest.closest('form');
                            if (!form) throw new Error("Formulaire non trouvé");

                            const typeInput = form.querySelector('[name$="[type]"]');
                            const capaciteInput = form.querySelector('[name$="[capacite]"]');
                            
                            // More robust lookup for price input
                            const priceInput = form.querySelector('[name$="[prixParNuit]"]') || document.getElementById('chambre_prix') || document.getElementById('chambre_prixParNuit');

                            if (!typeInput) throw new Error("Champ Type introuvable");
                            if (!capaciteInput) throw new Error("Champ Capacité introuvable");
                            if (!priceInput) throw new Error("Champ Prix introuvable (vérifiez l'ID ou le nom)");

                            const hebSelect = form.querySelector('select[name$="[hebergement]"]');
                            const hebText = (hebSelect && hebSelect.selectedIndex >= 0) ? hebSelect.options[hebSelect.selectedIndex].text : 'Non spécifié';

                            const data = {
                                type: typeInput.value,
                                capacite: capaciteInput.value,
                                hebergement: hebText,
                                ville: 'Tunisie', 
                                etoiles: 'Standard'
                            };

                            fetch('{{ path('app_chambre_ai_price') }}', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: JSON.stringify(data)
                            })
                            .then(response => {
                                if (!response.ok) {
                                    throw new Error("HTTP " + response.status);
                                }
                                return response.json();
                            })
                            .then(data => {
                                if(data.suggestion) {
                                    const match = data.suggestion.match(/(\d+([.,]\d+)?)/);
                                    if(match) {
                                        // Ensure we use the local variable which is checked
                                        if (priceInput) {
                                            priceInput.value = match[0].replace(',', '.');
                                        } else {
                                            alert("Suggestion: " + match[0] + " (Champ prix introuvable pour auto-fill)");
                                        }
                                    } else {
                                        alert('Suggestion: ' + data.suggestion);
                                    }
                                } else {
                                    alert('Erreur: Pas de suggestion reçue.');
                                }
                            })
                            .catch(err => {
                                console.error(err);
                                alert('Erreur technique: ' + err.message);
                            })
                            .finally(() => {
                                btnSuggest.innerHTML = originalText;
                                btnSuggest.disabled = false;
                            });
                        } catch (e) {
                            console.error(e);
                            alert('Erreur JS: ' + e.message);
                            btnSuggest.innerHTML = originalText;
                            btnSuggest.disabled = false;
                        }
                    });
                }
            });
        </script>
            </div>

            <div class="form-floating mb-4">
                {{ form_widget(form.hebergement, {'attr': {'class': 'form-select'}}) }}
                {{ form_label(form.hebergement, 'Hébergement Associé') }}
                {{ form_errors(form.hebergement) }}
            </div>

            <div class="form-floating mb-4">
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Description', 'style': 'height: 120px;'}}) }}
                {{ form_label(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light border">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="fw-bold mb-1">Disponibilité</h6>
                        <p class="text-muted small mb-0">Indiquer si la chambre est disponible à la réservation.</p>
                    </div>
                    <div class="form-check form-switch form-switch-lg">
                        {{ form_widget(form.disponible, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.disponible, ' ', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card-footer bg-white p-4 p-md-5 border-top-0 pt-0">
            <div class="d-flex flex-column flex-md-row gap-3">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-sm transition-all hover-lift">
                    <i class="bi bi-check-circle me-2"></i>{{ button_label|default('Enregistrer la chambre') }}
                </button>
                <a href="{{ path('app_chambre_index') }}" class="btn btn-light btn-lg rounded-pill px-5 py-3 border transition-all hover-lift">
                    <i class="bi bi-x-circle me-2"></i>Annuler
                </a>
            </div>
        </div>
    </div>
{{ form_end(form) }}

<style>
    .form-floating > .form-control:focus, .form-floating > .form-control:not(:placeholder-shown) {
        padding-top: 1.625rem;
        padding-bottom: 0.625rem;
    }
    .form-check-input { width: 3em !important; height: 1.5em !important; cursor: pointer; }
    .hover-lift:hover { transform: translateY(-2px); }
    .transition-all { transition: all 0.3s ease; }
</style>

<script>
    (function () {
      'use strict'
      const forms = document.querySelectorAll('.needs-validation')
      Array.prototype.slice.call(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
    })()
</script>
