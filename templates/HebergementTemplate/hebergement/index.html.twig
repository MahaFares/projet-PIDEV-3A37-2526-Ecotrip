{% extends 'BackOffice/base.html.twig' %}

{% block title %}Hébergements | EcoTrip Admin{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
.hebergement-mgmt { 
    font-family: 'Plus Jakarta Sans', sans-serif;
    padding: 2rem;
}

.page-header {
    margin-bottom: 2rem;
}

.page-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.5rem;
}

.toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    margin-bottom: 24px;
    background: white;
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.search-wrap {
    flex: 1;
    min-width: 220px;
    position: relative;
}

.search-wrap input {
    width: 100%;
    padding: 12px 16px 12px 44px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.95rem;
    transition: border-color 0.2s;
}

.search-wrap input:focus {
    outline: none;
    border-color: #3b82f6;
}

.search-wrap i { 
    position: absolute; 
    left: 16px; 
    top: 50%; 
    transform: translateY(-50%); 
    color: #94a3b8; 
}

.filter-wrap select, 
.filter-wrap input {
    padding: 12px 16px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.95rem;
    min-width: 140px;
    transition: border-color 0.2s;
}

.filter-wrap select:focus,
.filter-wrap input:focus {
    outline: none;
    border-color: #3b82f6;
}

.btn-add {
    padding: 12px 24px;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    border: none;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
}

.btn-add:hover { 
    color: white; 
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.table-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    overflow: hidden;
}

.table-card table { 
    width: 100%; 
    border-collapse: collapse; 
}

.table-card th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 600;
    font-size: 0.8rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
}

.table-card td {
    padding: 16px 20px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
    font-size: 0.95rem;
}

.table-card tbody tr {
    transition: background-color 0.2s;
}

.table-card tbody tr:hover {
    background: #fafbfc;
}

.badge-role { 
    padding: 6px 14px; 
    border-radius: 20px; 
    font-size: 0.75rem; 
    font-weight: 600; 
    display: inline-block; 
}

.badge-role.stars { 
    background: #fef3c7; 
    color: #b45309; 
}

.badge-verified { 
    padding: 6px 14px; 
    border-radius: 20px; 
    font-size: 0.75rem; 
    font-weight: 600; 
}

.badge-verified.yes { 
    background: #dcfce7; 
    color: #166534; 
}

.badge-verified.no { 
    background: #fee2e2; 
    color: #991b1b; 
}

.actions-cell {
    display: flex;
    gap: 8px;
}

.btn-action {
    display: inline-flex; 
    align-items: center; 
    justify-content: center;
    width: 36px; 
    height: 36px; 
    border-radius: 10px;
    color: #64748b; 
    text-decoration: none;
    transition: all 0.2s;
    border: none;
    background: #f1f5f9;
    cursor: pointer;
    font-size: 1rem;
}

.btn-action:hover { 
    color: white; 
    transform: translateY(-2px);
}

.btn-action.edit:hover { 
    background: #3b82f6; 
}

.btn-action.view:hover { 
    background: #10b981; 
}

.btn-action.delete:hover { 
    background: #ef4444; 
}

.loading-overlay {
    position: relative;
}

.loading-overlay.loading::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
}

.empty-state {
    text-align: center;
    padding: 3rem;
    color: #64748b;
}

.empty-state-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

/* Stat cards (above filters) */
.heb-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
}
.heb-stat-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: box-shadow 0.2s;
}
.heb-stat-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}
.heb-stat-card .icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
}
.heb-stat-card.total-heb .icon-wrap { background: linear-gradient(135deg, #dbeafe, #bfdbfe); color: #2563eb; }
.heb-stat-card.total-chambres .icon-wrap { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: #16a34a; }
.heb-stat-card h3 { font-size: 1.75rem; font-weight: 700; margin: 0 0 4px 0; color: #0f172a; }
.heb-stat-card p { margin: 0; font-size: 0.875rem; color: #64748b; }

/* Chart cards */
.heb-charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
@media (max-width: 768px) { .heb-charts-row { grid-template-columns: 1fr; } }
.heb-chart-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 1px solid #e2e8f0;
}
.heb-chart-card h4 { font-size: 1rem; font-weight: 600; margin: 0 0 16px 0; color: #0f172a; display: flex; align-items: center; gap: 8px; }
.heb-chart-wrap { height: 280px; position: relative; }
</style>
{% endblock %}

{% block body %}
<div class="hebergement-mgmt">
    <div class="page-header">
        <h1>🏨 Gestion des Hébergements</h1>
    </div>

    <div class="heb-stats-grid">
        <div class="heb-stat-card total-heb">
            <div class="icon-wrap"><i class="bi bi-building"></i></div>
            <div>
                <h3>{{ stats.total_hebergements|default(0) }}</h3>
                <p>Total hébergements</p>
            </div>
        </div>
        <div class="heb-stat-card total-chambres">
            <div class="icon-wrap"><i class="bi bi-door-open"></i></div>
            <div>
                <h3>{{ stats.total_chambres|default(0) }}</h3>
                <p>Total chambres</p>
            </div>
        </div>
    </div>

    <div class="heb-charts-row">
        <div class="heb-chart-card">
            <h4><i class="bi bi-pie-chart"></i> Hébergements par catégorie</h4>
            <div class="heb-chart-wrap"><canvas id="chartHebPie"></canvas></div>
        </div>
        <div class="heb-chart-card">
            <h4><i class="bi bi-bar-chart"></i> Top 5 hébergements (nombre de chambres)</h4>
            <div class="heb-chart-wrap"><canvas id="chartHebBar"></canvas></div>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" name="q" value="{{ filters.q|default('') }}" placeholder="Rechercher (nom, adresse, ville)...">
        </div>
        <div class="filter-wrap">
            <input type="number" id="minStars" name="minStars" value="{{ filters.minStars is not null ? filters.minStars : '' }}" placeholder="⭐ Min" style="width: 120px;" min="1" max="5">
        </div>
        <div class="filter-wrap">
            <input type="number" id="maxStars" name="maxStars" value="{{ filters.maxStars is not null ? filters.maxStars : '' }}" placeholder="⭐ Max" style="width: 120px;" min="1" max="5">
        </div>
        <div class="filter-wrap">
            <select id="activeFilter" name="active">
                <option value="">Statut: Tous</option>
                <option value="1" {% if filters.active is same as(true) %}selected{% endif %}>Actif</option>
                <option value="0" {% if filters.active is same as(false) %}selected{% endif %}>Inactif</option>
            </select>
        </div>
        <a href="{{ path('app_hebergement_new') }}" class="btn-add">
            <i class="bi bi-plus-lg"></i> Nouveau Hébergement
        </a>
    </div>

    <div id="hebergementContainer">
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>IMAGE</th>
                        <th>HÉBERGEMENT</th>
                        <th>ADRESSE</th>
                        <th>VILLE</th>
                        <th>ÉTOILES</th>
                        <th>STATUT</th>
                        <th>ACTIONS</th>
                    </tr>
                </thead>
                <tbody id="hebergementTableBody">
                    {% for hebergement in hebergements %}
                    <tr>
                        <td style="width: 80px;">
                            {% if hebergement.imagePrincipale %}
                                <img src="{{ hebergement.imagePrincipale starts with 'http' ? hebergement.imagePrincipale : asset(hebergement.imagePrincipale) }}" alt="{{ hebergement.nom }}"
                                     style="width: 60px; height: 60px; border-radius: 12px; object-fit: cover; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                            {% else %}
                                <div style="width: 60px; height: 60px; border-radius: 12px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                    <i class="bi bi-image"></i>
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            <strong>{{ hebergement.nom }}</strong>
                        </td>
                        <td>{{ hebergement.adresse }}</td>
                        <td>{{ hebergement.ville }}</td>
                        <td>
                            <span class="badge-role stars">⭐ {{ hebergement.nbEtoiles }}</span>
                        </td>
                        <td>
                            {% if hebergement.actif %}
                                <span class="badge-verified yes">✓ Actif</span>
                            {% else %}
                                <span class="badge-verified no">✗ Inactif</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="actions-cell">
                                <a href="{{ path('app_hebergement_show', {'id': hebergement.id}) }}" class="btn-action view" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_hebergement_edit', {'id': hebergement.id}) }}" class="btn-action edit" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-action delete" title="Supprimer" onclick="deleteHebergement({{ hebergement.id }})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <div class="empty-state-icon">🏨</div>
                                <p>Aucun hébergement trouvé.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center mt-4 pagination-container">
            {{ knp_pagination_render(hebergements, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Elements
        const searchInput = document.getElementById('searchInput');
        const minStarsInput = document.getElementById('minStars');
        const maxStarsInput = document.getElementById('maxStars');
        const activeFilter = document.getElementById('activeFilter');
        const container = document.getElementById('hebergementContainer');
        const tableBody = document.getElementById('hebergementTableBody');

        let timeout = null;

        function fetchResults(page = 1) {
            // Collect All Values
            const q = searchInput.value;
            const minStars = minStarsInput.value;
            const maxStars = maxStarsInput.value;
            const active = activeFilter.value;

            const params = new URLSearchParams({
                q: q,
                minStars: minStars,
                maxStars: maxStars,
                active: active,
                page: page
            });

            // Update URL without page reload
            const newUrl = window.location.pathname + '?' + params.toString();
            window.history.pushState({}, '', newUrl);

            // Opacity for loading effect
            container.style.opacity = '0.5';

            fetch(newUrl, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const newContent = doc.querySelector('#hebergementContainer');
                
                if (newContent) {
                    container.innerHTML = newContent.innerHTML;
                }
                
                container.style.opacity = '1';
            })
            .catch(error => {
                console.error('Error:', error);
                container.style.opacity = '1';
            });
        }

        // Event Listeners with debounce
        const inputs = [searchInput, minStarsInput, maxStarsInput];
        inputs.forEach(input => {
            input.addEventListener('input', () => {
                clearTimeout(timeout);
                timeout = setTimeout(() => fetchResults(1), 300);
            });
        });

        activeFilter.addEventListener('change', () => fetchResults(1));

        // Event delegation for pagination links
        container.addEventListener('click', function(e) {
            const link = e.target.closest('.pagination a');
            if (link) {
                e.preventDefault();
                const url = new URL(link.href);
                const page = url.searchParams.get('page') || 1;
                fetchResults(page);
            }
        });
    });

    // Delete function
    function deleteHebergement(id) {
        if (confirm('Êtes-vous sûr de vouloir supprimer cet hébergement ?')) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/hebergement/' + id;

            const csrfInput = document.createElement('input');
            csrfInput.type = 'hidden';
            csrfInput.name = '_token';
            csrfInput.value = 'delete' + id;

            form.appendChild(csrfInput);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    const pieLabels = {{ chartPieLabels|default([])|json_encode|raw }};
    const pieData = {{ chartPieData|default([])|json_encode|raw }};
    const barLabels = {{ chartBarLabels|default([])|json_encode|raw }};
    const barData = {{ chartBarData|default([])|json_encode|raw }};
    const pieColors = ['#2563eb', '#16a34a', '#ea580c', '#7c3aed', '#dc2626', '#0d9488', '#ca8a04', '#db2777'];

    if (pieLabels.length > 0) {
        new Chart(document.getElementById('chartHebPie'), {
            type: 'pie',
            data: {
                labels: pieLabels,
                datasets: [{ data: pieData, backgroundColor: pieColors.slice(0, pieLabels.length) }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    } else {
        document.getElementById('chartHebPie').parentElement.innerHTML = '<p class="text-muted text-center py-5 mb-0">Aucune donnée</p>';
    }

    if (barLabels.length > 0) {
        new Chart(document.getElementById('chartHebBar'), {
            type: 'bar',
            data: {
                labels: barLabels,
                datasets: [{
                    label: 'Nombre de chambres',
                    data: barData,
                    backgroundColor: '#2563eb',
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true, ticks: { stepSize: 1 } },
                    y: { ticks: { maxRotation: 0, autoSkip: false } }
                }
            }
        });
    } else {
        document.getElementById('chartHebBar').parentElement.innerHTML = '<p class="text-muted text-center py-5 mb-0">Aucun hébergement</p>';
    }
})();
</script>
{% endblock %}
