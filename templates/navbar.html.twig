<header class="header_area">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-light">
            <a class="navbar-brand logo_h" href="{{ path('app_home') }}"><img src="{{ asset('images/logo.jpg') }}" alt="Royal Hotel"></a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <div class="collapse navbar-collapse offset" id="navbarSupportedContent">
                <ul class="nav navbar-nav menu_nav ml-auto">
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Home</a></li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_about' ? 'active' : '' }}" href="{{ path('app_about') }}">A propos</a></li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_hebergement' ? 'active' : '' }}" href="{{ path('app_hebergement') }}">Hébergement</a></li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_activites' ? 'active' : '' }}" href="{{ path('app_activites') }}">Activité</a></li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_transport' ? 'active' : '' }}" href="{{ path('app_transport') }}">Transport</a></li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_boutique' ? 'active' : '' }}" href="{{ path('app_boutique') }}">Boutique</a></li>
                    <li class="nav-item">
                        <a class="nav-link {{ (active_route|default('')) == 'app_panier_index' ? 'active' : '' }}" href="{{ path('app_panier_index') }}" style="position:relative;">
                            <i class="fa fa-shopping-cart"></i> Panier
                            {% set cart_count = cart_count() %}
<span id="cartBadge" class="badge bg-danger rounded-pill" style="position:absolute;top:-5px;right:-8px;font-size:0.65rem;{{ cart_count > 0 ? '' : 'display:none;' }}">{{ cart_count }}</span>
                        </a>
                    </li>
                    <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_contact' ? 'active' : '' }}" href="{{ path('app_contact') }}">Contact</a></li>
                    {% if app.user %}
                        <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_mes_reservations' ? 'active' : '' }}" href="{{ path('app_mes_reservations') }}">Mes réservations</a></li>
                        <li class="nav-item"><a class="nav-link {{ (active_route|default('')) in ['app_front_mon_compte', 'app_front_update_account', 'app_front_change_password'] ? 'active' : '' }}" href="{{ path('app_front_mon_compte') }}">Mon compte</a></li>
                        <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_logout' ? 'active' : '' }}" href="{{ path('app_logout') }}">Se déconnecter</a></li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link {{ (active_route|default('')) == 'app_login' ? 'active' : '' }}" href="{{ path('app_login') }}">Se connecter/S'inscrire</a></li>
                    {% endif %}
                    
                    <!-- Language Switcher - same row, working dropdown -->
                    <li class="nav-item dropdown lang-dropdown" id="langDropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="langSelector" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="font-weight: 700; color: #2d5016 !important;">
                            <i class="fa fa-globe"></i> <span id="current-lang-text">FR</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="langSelector" id="langDropdownMenu">
                            <a class="dropdown-item lang-opt" href="#" data-lang="fr"><img src="https://flagcdn.com/16x12/fr.png" width="16" height="12" class="mr-2"> Français</a>
                            <a class="dropdown-item lang-opt" href="#" data-lang="en"><img src="https://flagcdn.com/16x12/gb.png" width="16" height="12" class="mr-2"> English</a>
                            <a class="dropdown-item lang-opt" href="#" data-lang="es"><img src="https://flagcdn.com/16x12/es.png" width="16" height="12" class="mr-2"> Español</a>
                        </div>
                    </li>
                </ul>
            </div>
        </nav>
    </div>
</header>
